# --- PostgreSQL (Supabase) ---
# This single long-running server uses the SESSION connection (port 5432) for both — it is more
# stable than the transaction pooler (6543), which targets serverless/edge and drops idle
# connections on the free tier (causes intermittent P1001 "can't reach database server").
# URL-encode special characters in the password (e.g. * -> %2A).
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres"
# (Serverless/edge deploy instead? Use the transaction pooler for DATABASE_URL:
#  ...pooler.supabase.com:6543/postgres?pgbouncer=true , and keep DIRECT_URL on 5432 for migrations.)

# For a plain local Postgres instead, use a single direct URL for both:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creditly?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/creditly?schema=public"

# --- JWT ---
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="1d"

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Cookie ---
COOKIE_SECURE=false

# --- Mock CRM integration ---
CRM_FAIL_RATE=0          # 0..1 — probability a CRM sync attempt fails (for testing retry/failure)
CRM_MAX_RETRIES=3
CRM_RETRY_BASE_MS=100
